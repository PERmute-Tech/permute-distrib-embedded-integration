{
  "name": "permute-distrib-embedded-integration",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 5500",
    "build": "next build",
    "start": "next start -p 5500",
    "pretty": "prettier -w .",
    "lint": "eslint .",
    "lint:next": "cross-env SKIP_ENV_VALIDATION=true next lint",
    "lint:ts": "tsc --noEmit",
    "lint:prettier": "prettier --check ./src",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:ci:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@t3-oss/env-nextjs": "0.7.3",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitest/coverage-v8": "1.5.0",
    "cross-env": "7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.12",
    "prettier": "3.3.3",
    "typescript": "5.4.2",
    "vitest": "1.5.0"
  }
}
