# ──────────────────────────────────────────────────────────────────────────
# permute-distrib-embedded-integration — client CRM simulator
# Copy this file to `.env`. The endpoints and the service-account secret are
# provided by Permute (out-of-band). NEVER commit the `.env` file.
# ──────────────────────────────────────────────────────────────────────────

DISTRIBUTEUR_API_BASE_URL="https://api.permute-app.fr/distributeur"

KEYCLOAK_BASE_URL="https://secure.permute-app.fr"

KEYCLOAK_REALM="distributeur"

DEMO_TENANT_SLUG="demodistrib"

# External service account provided by Permute (client_credentials grant).
SA_CLIENT_ID="ccs-service-account"
SA_CLIENT_SECRET="<secret-fourni-par-permute>"

# Gating: the app is inert (404) when "production".
NEXT_PUBLIC_ENV="development"
